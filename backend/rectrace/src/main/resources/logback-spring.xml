<?xml version="1.0" encoding="UTF-8"?>
<!--
  OBS-01 / OBS-07 — Profile-aware structured logging.

  In !prod profile: human-readable ConsoleAppender (CONSOLE) for laptop dev/UAT/test.
  In  prod profile: STDOUT_JSON (JSON to stdout/journald) + FILE_JSON (rotating JSON file).
                    Splunk (SPLUNK_HEC) is OPT-IN — add the `splunk` profile alongside prod
                    (SPRING_PROFILES_ACTIVE=prod,splunk) and set splunk.hec.host. It is OFF by
                    default so an unset/empty Splunk host can never break startup (a host-less
                    TCP destination throws at config time).

  Filename pitfall P-1: this file MUST be logback-spring.xml (NOT logback.xml).
  Logback evaluates logback.xml BEFORE Spring activates profiles, so <springProfile>
  blocks would silently be ignored — every appender would attach unconditionally.

  See .planning/phases/07-observability-sweep/07-RESEARCH.md §3.1 and
      .planning/phases/07-observability-sweep/07-02-PLAN.md Task 1.
-->
<configuration>
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <!-- Local / dev / test / uat — human-readable console -->
  <springProfile name="!prod">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [traceId=%X{traceId:-} userId=%X{userId:-}] %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
  </springProfile>

  <!-- Production — Splunk HEC compatible JSON over TCP, plus STDOUT JSON fallback -->
  <springProfile name="prod">
    <springProperty scope="context" name="appName" source="spring.application.name"/>
    <springProperty scope="context" name="logDir" source="logging.file.path"
                    defaultValue="logs"/>

    <!-- Local recovery surface: JSON-encoded stdout. Captured by systemd/journald
         on the VM so operators always have a log surface even if Splunk is down. -->
    <appender name="STDOUT_JSON" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <includeMdc>true</includeMdc>
        <includeContext>false</includeContext>
        <customFields>{"application":"${appName}","environment":"prod"}</customFields>
        <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
        <timeZone>UTC</timeZone>
      </encoder>
    </appender>

    <!-- Splunk HEC — OPT-IN, nested under the `splunk` profile so the appender (and its
         host/port properties) are NOT constructed unless SPRING_PROFILES_ACTIVE=prod,splunk.
         This makes Splunk truly optional: an unset/empty splunk.hec.host can never reach the
         LogstashTcpSocketAppender (a host-less destination throws at config time).

         Raw-TCP HEC is auth-by-source-IP today (D-7.14); splunk.hec.token is reserved for a
         future HTTPS-HEC migration and is unused. Pitfall P-2: LogstashTcpSocketAppender is
         inherently async (LMAX disruptor via <ringBufferSize>); attached directly to root,
         not wrapped in an AsyncAppender. -->
    <springProfile name="splunk">
      <springProperty scope="context" name="splunkHost" source="splunk.hec.host"
                      defaultValue="splunk.citi.intra.example"/>
      <springProperty scope="context" name="splunkPort" source="splunk.hec.port"
                      defaultValue="9997"/>
      <appender name="SPLUNK_HEC"
                class="net.logstash.logback.appender.LogstashTcpSocketAppender">
        <destination>${splunkHost}:${splunkPort}</destination>
        <reconnectionDelay>30 seconds</reconnectionDelay>
        <writeTimeout>10 seconds</writeTimeout>
        <keepAliveDuration>5 minutes</keepAliveDuration>
        <ringBufferSize>8192</ringBufferSize>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
          <includeMdc>true</includeMdc>
          <includeContext>false</includeContext>
          <customFields>{"application":"${appName}","environment":"prod"}</customFields>
          <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
          <timeZone>UTC</timeZone>
        </encoder>
      </appender>
    </springProfile>

    <!-- Always-on rotating JSON file: gives operators a flat log file even when
         Splunk is down and journald is not used. Path is ${logging.file.path}/rectrace.log
         (defaults to ./logs relative to the run dir; set logging.file.path to an absolute
         path like /opt/rectrace/logs in prod). Daily + 100 MB rollover, gzip,
         30-day / 3 GB retention. -->
    <appender name="FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${logDir}/rectrace.log</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
        <fileNamePattern>${logDir}/rectrace-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
        <maxFileSize>100MB</maxFileSize>
        <maxHistory>30</maxHistory>
        <totalSizeCap>3GB</totalSizeCap>
      </rollingPolicy>
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <includeMdc>true</includeMdc>
        <includeContext>false</includeContext>
        <customFields>{"application":"${appName}","environment":"prod"}</customFields>
        <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
        <timeZone>UTC</timeZone>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="STDOUT_JSON"/>
      <appender-ref ref="FILE_JSON"/>
      <!-- Splunk attached only when the `splunk` profile is active (appender defined above). -->
      <springProfile name="splunk">
        <appender-ref ref="SPLUNK_HEC"/>
      </springProfile>
    </root>
  </springProfile>
</configuration>
